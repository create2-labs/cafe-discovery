# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
WORKER_HEALTH_PORT=8081

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=cafe
POSTGRES_USER=cafe
POSTGRES_PASSWORD=cafe
POSTGRES_SSLMODE=disable

# NATS Configuration
NATS_URL=nats://localhost:4222

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration (required for authentication)
# Note: The service always uses hybrid PQC tokens (EdDSA + ML-DSA-65)
# JWT_SECRET is kept for API compatibility but not used for token signing
JWT_SECRET=your-secret-key-here

# Moralis API (required for wallet scanning features)
# Get your API key from https://moralis.io
MORALIS_API_KEY=your_api_key_here
MORALIS_API_URL=https://deep-index.moralis.io

# Cloudflare Turnstile (required for signup/signin protection)
# Get your keys from https://developers.cloudflare.com/turnstile/
# Site Key: Public key (configure in frontend as VITE_TURNSTILE_SITE_KEY)
# Secret Key: Private key (configure here for backend verification)
# Note: If TURNSTILE_SECRET_KEY is not set, verification is skipped (development mode only)
TURNSTILE_SECRET_KEY=your_secret_key_here
TURNSTILE_SITE_KEY=your_site_key_here

# Logging
LOG_LEVEL=info
