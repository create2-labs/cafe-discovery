##############################
# Stage 1 — Build everything
##############################
FROM debian:bookworm AS builder

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential cmake ninja-build git pkg-config libssl-dev ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /root

COPY install_oqs_openssl_debian.sh /root/install_oqs_openssl_debian.sh
RUN chmod +x /root/install_oqs_openssl_debian.sh

RUN /root/install_oqs_openssl_debian.sh


##############################
# Stage 2 — Slim runtime image
##############################
FROM debian:bookworm-slim

ARG DEBIAN_FRONTEND=noninteractive
ENV LIBOQS_PREFIX=/opt/liboqs

RUN apt-get update && \
    apt-get install -y libssl3 ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Copy liboqs + openssl.cnf from builder
COPY --from=builder /opt/liboqs /opt/liboqs
COPY --from=builder /etc/ssl/openssl.cnf /etc/ssl/openssl.cnf

# Detect multi-arch target (ex: aarch64-linux-gnu)
RUN ARCH=$(uname -m) && ARCH_DIR=${ARCH}-linux-gnu && \
    mkdir -p /usr/lib/${ARCH_DIR}/ossl-modules && \
    echo "${ARCH_DIR}" > /arch.txt

# Copy oqsprovider.so into runtime
COPY --from=builder /usr/lib/aarch64-linux-gnu/ossl-modules/oqsprovider.so \
    /usr/lib/aarch64-linux-gnu/ossl-modules/oqsprovider.so

# Environment
ENV OPENSSL_CONF=/etc/ssl/openssl.cnf
ENV LD_LIBRARY_PATH=/opt/liboqs/lib

# Dynamic OPENSSL_MODULES
RUN echo '#!/bin/sh\n\
ARCH=$(uname -m)\n\
ARCH_DIR=${ARCH}-linux-gnu\n\
export OPENSSL_MODULES=/usr/lib/${ARCH_DIR}/ossl-modules\n\
exec "$@"' > /entrypoint.sh \
    && chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]

CMD ["bash"]
